# ============================================
# AuraWed AI婚礼策划平台 - 环境配置
# ============================================
# 复制此文件为 .env.local 并填入真实配置

# ============================================
# Supabase 配置 (必需)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# Google Gemini API 配置 (文字生成 + 图片生成)
# 获取地址: https://aistudio.google.com/app/apikey
# ============================================
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash-exp
GEMINI_IMAGE_MODEL=imagen-3-generate-002

# ============================================
# 图片生成 API (可选，选择一个即可)
# ============================================

# Google Gemini (推荐，一站式解决方案)
# 使用 Gemini 的 Imagen 模型生成图片
GEMINI_IMAGE_API_KEY=your-gemini-api-key

# ============================================
# 应用配置
# ============================================
# 生成婚礼方案时的默认语言
NEXT_PUBLIC_DEFAULT_LANGUAGE=zh-CN

# AI 模型配置
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# 生成图片的默认尺寸
DEFAULT_IMAGE_WIDTH=1792
DEFAULT_IMAGE_HEIGHT=1024
